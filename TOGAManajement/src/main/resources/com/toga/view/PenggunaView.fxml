<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.toga.controller.PenggunaController"
            styleClass="scroll-pane">
    <VBox spacing="16" styleClass="page-container">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <Label text="Kelola Pengguna" styleClass="page-title"/>

        <!-- FORM COMPACT -->
        <VBox styleClass="card" spacing="12">
            <Label text="👤 Form Pengguna" styleClass="section-title"/>

            <HBox spacing="14">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Nama Lengkap" styleClass="form-label"/>
                    <TextField fx:id="tfNama" promptText="Nama anggota" styleClass="form-field"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Alamat" styleClass="form-label"/>
                    <TextField fx:id="tfAlamat" promptText="Alamat lengkap" styleClass="form-field"/>
                </VBox>
            </HBox>

            <HBox spacing="10">
                <Button text="Tambah" onAction="#handleTambah" styleClass="btn-primary"/>
                <Button text="Ubah" onAction="#handleUbah" styleClass="btn-secondary"/>
                <Button text="Hapus" onAction="#handleHapus" styleClass="btn-danger"/>
            </HBox>
        </VBox>

        <!-- TABLE -->
        <VBox styleClass="card" spacing="10">
            <Label text="📋 Daftar Pengguna" styleClass="section-title"/>
            <TableView fx:id="tblPengguna" styleClass="modern-table" prefHeight="350">
                <columns>
                    <TableColumn fx:id="colNama" text="Nama" prefWidth="250"/>
                    <TableColumn fx:id="colAlamat" text="Alamat" prefWidth="450"/>
                </columns>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>