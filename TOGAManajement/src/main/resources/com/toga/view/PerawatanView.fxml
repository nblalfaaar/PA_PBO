<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.toga.controller.PerawatanController"
            styleClass="scroll-pane">
    <VBox spacing="14" styleClass="page-container">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <Label text="Jadwal Perawatan" styleClass="page-title"/>

        <Label fx:id="lblBelumHariIni" text="0 jadwal belum dilakukan hari ini" styleClass="alert-label"/>

        <!-- FORM TAMBAH JADWAL -->
        <VBox styleClass="card" spacing="10">
            <Label text="➕ Tambah Jadwal" styleClass="section-title"/>
            <GridPane hgap="12" vgap="8">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33"/>
                    <ColumnConstraints percentWidth="33"/>
                    <ColumnConstraints percentWidth="34"/>
                </columnConstraints>

                <Label text="Tanaman" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="cmbTanaman" styleClass="form-field" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="Jenis Perawatan" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <ComboBox fx:id="cmbJenisPerawatan" styleClass="form-field" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Tanggal" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <DatePicker fx:id="dpTanggal" styleClass="form-field" maxWidth="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            </GridPane>
        </VBox>

        <!-- FORM TANDAI SELESAI -->
        <VBox styleClass="card" spacing="10">
            <Label text="✅ Tandai Selesai" styleClass="section-title"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Pilih Pengguna yang Merawat" styleClass="form-label"/>
                    <ComboBox fx:id="cmbPengguna" styleClass="form-field" maxWidth="Infinity"/>
                </VBox>
            </HBox>
        </VBox>

        <HBox spacing="10">
            <Button text="Tambah Jadwal" onAction="#handleTambah" styleClass="btn-primary"/>
            <Button text="Tandai Selesai" onAction="#handleTandaiSelesai" styleClass="btn-secondary"/>
            <Button text="Hapus" onAction="#handleHapus" styleClass="btn-danger"/>
        </HBox>

        <!-- TABLE -->
        <VBox styleClass="card" spacing="10">
            <Label text="📅 Daftar Jadwal Perawatan" styleClass="section-title"/>
            <TableView fx:id="tblJadwal" styleClass="modern-table" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colTanaman" text="Tanaman" prefWidth="150"/>
                    <TableColumn fx:id="colJenis" text="Jenis Perawatan" prefWidth="140"/>
                    <TableColumn fx:id="colTanggal" text="Tanggal" prefWidth="110"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
                    <TableColumn fx:id="colPetugas" text="Petugas" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>