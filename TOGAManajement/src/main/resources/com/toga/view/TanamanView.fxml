<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.toga.controller.TanamanController"
            styleClass="scroll-pane">
    <VBox spacing="16" styleClass="page-container">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <Label text="Kelola Tanaman" styleClass="page-title"/>

        <!-- FORM -->
        <VBox styleClass="card" spacing="12">
            <Label text="Form Tanaman" styleClass="section-title"/>

            <GridPane hgap="14" vgap="10">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>

                <Label text="Jenis" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="cmbJenis" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="Nama Tanaman" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <TextField fx:id="tfNama" promptText="cth: Jahe" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Nama Latin" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <TextField fx:id="tfNamaLatin" promptText="cth: Zingiber officinale" styleClass="form-field" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                <Label fx:id="lblProperti" text="Properti" styleClass="form-label" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                <TextField fx:id="tfProperti" promptText="Aroma/Bentuk/Musim" styleClass="form-field" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                <Label text="Tgl Tanam" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <DatePicker fx:id="dpTanggal" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                <Label text="Estimasi (hari)" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <TextField fx:id="tfEstimasiHari" promptText="cth: 120" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Status Preview" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                <Label fx:id="lblStatusInfo" text="Isi estimasi" styleClass="status-preview" GridPane.columnIndex="2" GridPane.rowIndex="3"/>

                <Label text="Manfaat" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextArea fx:id="taManfaat" prefHeight="50" promptText="Manfaat tanaman..." styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="4" GridPane.columnSpan="3"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="Tambah" onAction="#handleTambah" styleClass="btn-primary"/>
                <Button text="Ubah"   onAction="#handleUbah"   styleClass="btn-secondary"/>
                <Button text="Hapus"  onAction="#handleHapus"  styleClass="btn-danger"/>
            </HBox>
        </VBox>

        <!-- TABLE -->
        <VBox styleClass="card" spacing="10">
            <Label text="Daftar Tanaman" styleClass="section-title"/>
            <TableView fx:id="tblTanaman" styleClass="modern-table" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colNama"      text="Nama"            prefWidth="140"/>
                    <TableColumn fx:id="colJenis"     text="Jenis"           prefWidth="130"/>
                    <TableColumn fx:id="colNamaLatin" text="Nama Latin"      prefWidth="180"/>
                    <TableColumn fx:id="colEstimasi"  text="Estimasi (hari)" prefWidth="100"/>
                    <TableColumn fx:id="colStatus"    text="Status"          prefWidth="120"/>
                    <TableColumn fx:id="colAksi"      text="Aksi"            prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>